#:kivy 2.3
# ============================================================
#  贞人占卜 — 商周青铜风 UI 设计
#  配色：玄黑底 / 古铜金 / 朱砂红 / 宣纸白 / 青铜绿
# ============================================================

# ---------- 可复用装饰：回纹横线 ----------
<-DecorTop@BoxLayout>:
    size_hint_y: None
    height: 36
    padding: 12, 0
    canvas.before:
        Color:
            rgba: 0.82, 0.63, 0.25, 0.6
        Rectangle:
            pos: self.x + 12, self.center_y - 0.5
            size: self.width - 24, 1
    canvas:
        Color:
            rgba: 0.82, 0.63, 0.25, 1
        Rectangle:
            pos: self.center_x - 3, self.center_y - 3
            size: 6, 6
        Color:
            rgba: 0.75, 0.18, 0.12, 1
        Rectangle:
            pos: self.x + 12, self.center_y - 0.5
            size: 8, 1
        Rectangle:
            pos: self.right - 20, self.center_y - 0.5
            size: 8, 1

<-DecorDivider@BoxLayout>:
    size_hint_y: None
    height: 28
    canvas:
        Color:
            rgba: 0.82, 0.63, 0.25, 0.3
        Rectangle:
            pos: self.x + 24, self.center_y - 0.5
            size: self.width - 48, 0.5
        Color:
            rgba: 0.75, 0.18, 0.12, 0.8
        Ellipse:
            pos: self.center_x - 2, self.center_y - 2
            size: 4, 4


<HomeScreen>:
    name: "home"
    BoxLayout:
        orientation: "vertical"
        canvas.before:
            Color:
                rgba: 0.06, 0.04, 0.02, 1    # 玄墨底
            Rectangle:
                pos: self.pos
                size: self.size
            # 中央青铜锈色光晕
            Color:
                rgba: 0.09, 0.07, 0.04, 0.4
            Ellipse:
                pos: self.center_x - 100, self.center_y - 40
                size: 200, 260
            # 龙鳞暗纹 — 极淡菱形格
            Color:
                rgba: 0.82, 0.63, 0.25, 0.03
        canvas.after:
            # === 左上祥云纹 ===
            Color:
                rgba: 0.82, 0.63, 0.25, 0.06
            Ellipse:
                pos: self.x + 4, self.y + self.height - 52
                size: 38, 28
            Ellipse:
                pos: self.x + 16, self.y + self.height - 62
                size: 24, 18
            Color:
                rgba: 0.82, 0.63, 0.25, 0.04
            Ellipse:
                pos: self.x, self.y + self.height - 42
                size: 52, 20
            Color:
                rgba: 0.82, 0.63, 0.25, 0.07
            Line:
                points:
                    self.x + 22, self.y + self.height - 38, self.x + 12, self.y + self.height - 24, self.x - 2, self.y + self.height - 18
                width: 1.2
            # === 右上祥云纹 ===
            Color:
                rgba: 0.82, 0.63, 0.25, 0.06
            Ellipse:
                pos: self.right - 42, self.y + self.height - 52
                size: 38, 28
            Ellipse:
                pos: self.right - 40, self.y + self.height - 62
                size: 24, 18
            Color:
                rgba: 0.82, 0.63, 0.25, 0.04
            Ellipse:
                pos: self.right - 52, self.y + self.height - 42
                size: 52, 20
            Color:
                rgba: 0.82, 0.63, 0.25, 0.07
            Line:
                points:
                    self.right - 22, self.y + self.height - 38, self.right - 12, self.y + self.height - 24, self.right + 2, self.y + self.height - 18
                width: 1.2
            # === 下方凤羽弧线 ===
            Color:
                rgba: 0.75, 0.18, 0.12, 0.03
            Line:
                points:
                    self.x - 10, self.y + 60, self.center_x - 50, self.y + 40, self.center_x, self.y + 45, self.center_x + 50, self.y + 40, self.right + 10, self.y + 60
                width: 35
            Color:
                rgba: 0.82, 0.63, 0.25, 0.04
            Line:
                points:
                    self.x - 5, self.y + 45, self.center_x, self.y + 25, self.right + 5, self.y + 45
                width: 20

        # ---- 顶部装饰 ----
        DecorTop:
            size_hint_y: None
            height: 20

        # ---- 标题区 ----
        BoxLayout:
            size_hint_y: None
            height: 160
            orientation: "vertical"
            padding: 0, 20, 0, 0
            spacing: 8
            canvas.before:
                Color:
                    rgba: 0.1, 0.07, 0.04, 0.4
                Rectangle:
                    pos: self.x + 20, self.y
                    size: self.width - 40, self.height
            Label:
                text: "贞 人 占 卜"
                font_size: "40sp"
                bold: True
                color: 0.84, 0.67, 0.30, 1     # 古铜金
                size_hint_y: None
                height: 56
            Label:
                text: "—— 以商周之力 · 问天地之心 ——"
                font_size: "13sp"
                color: 0.75, 0.18, 0.12, 1      # 朱砂红
                size_hint_y: None
                height: 24
            Label:
                text: "灼龟取兆，观纹知命"
                font_size: "12sp"
                color: 0.42, 0.37, 0.30, 1       # 古铜暗色
                size_hint_y: None
                height: 20

        DecorDivider:

        # ---- 输入区 ----
        BoxLayout:
            size_hint_y: 1
            orientation: "vertical"
            padding: 30, 15, 30, 10
            spacing: 12
            Label:
                text: "祈 问 事 项"
                font_size: "15sp"
                bold: True
                color: 0.84, 0.67, 0.30, 1
                size_hint_y: None
                height: 28
            TextInput:
                id: question_input
                hint_text: "所求何事？所忧何物？\n——写下你心中所念——"
                hint_text_color: 0.30, 0.26, 0.20, 1
                foreground_color: 0.93, 0.89, 0.78, 1
                background_color: 0.08, 0.06, 0.03, 0.9
                cursor_color: 0.84, 0.67, 0.30, 1
                font_size: "16sp"
                multiline: True
                padding: 18, 18
                canvas.before:
                    Color:
                        rgba: 0.82, 0.63, 0.25, 0.25
                    Line:
                        rectangle: self.x + 2, self.y + 2, self.width - 4, self.height - 4
                        width: 1.2

        # ---- 按钮区 ----
        BoxLayout:
            size_hint_y: None
            height: 140
            orientation: "vertical"
            padding: 30, 10, 30, 30
            spacing: 10
            # 占卜按钮 — 金底朱字风
            Button:
                text: "🔥  开 始 占 卜"
                font_size: "19sp"
                bold: True
                color: 0.08, 0.05, 0.02, 1
                background_normal: ""
                background_color: 0.84, 0.67, 0.30, 1
                size_hint_y: None
                height: 54
                canvas.before:
                    Color:
                        rgba: 0.72, 0.55, 0.22, 1
                    Line:
                        rectangle: self.x + 2, self.y + 2, self.width - 4, self.height - 4
                        width: 1.5
                    Color:
                        rgba: 0.06, 0.04, 0.02, 1
                    Line:
                        rectangle: self.x + 0, self.y + 0, self.width, self.height
                        width: 2
                on_release:
                    root.do_divination(question_input.text)
            # 历史按钮 — 暗底金边
            Button:
                text: "阅 览 过 往 卜 辞"
                font_size: "14sp"
                color: 0.84, 0.67, 0.30, 1
                background_normal: ""
                background_color: 0.10, 0.08, 0.04, 0.8
                size_hint_y: None
                height: 44
                canvas.before:
                    Color:
                        rgba: 0.82, 0.63, 0.25, 0.4
                    Line:
                        rectangle: self.x + 1, self.y + 1, self.width - 2, self.height - 2
                        width: 1
                on_release:
                    app.root.current = "history"

        DecorTop:


<CeremonyScreen>:
    name: "ceremony"
    BoxLayout:
        orientation: "vertical"
        spacing: 20
        canvas.before:
            Color:
                rgba: 0.06, 0.04, 0.02, 1
            Rectangle:
                pos: self.pos
                size: self.size
            # 龟甲轮廓暗示
            Color:
                rgba: 0.82, 0.63, 0.25, 0.04
            Ellipse:
                pos: self.center_x - 70, self.center_y - 50
                size: 140, 180
            Color:
                rgba: 0.82, 0.63, 0.25, 0.03
            Line:
                ellipse: self.center_x - 70, self.center_y - 50, 140, 180
                width: 1
        canvas:
            # 火焰光晕
            Color:
                rgba: 0.95, 0.42, 0.08, 0.15
            Ellipse:
                pos: self.center_x - 100, self.y + 20
                size: 200, 80
            Color:
                rgba: 0.95, 0.55, 0.12, 0.09
            Ellipse:
                pos: self.center_x - 130, self.y + 10
                size: 260, 60
            # 火星粒子
            Color:
                rgba: 0.95, 0.60, 0.15, 0.45
            Ellipse:
                pos: self.center_x - 70, self.y + 50
                size: 3, 3
            Ellipse:
                pos: self.center_x + 35, self.y + 38
                size: 2.5, 2.5
            Ellipse:
                pos: self.center_x - 25, self.y + 58
                size: 3, 3
            # 两侧云纹
            Color:
                rgba: 0.82, 0.63, 0.25, 0.05
            Ellipse:
                pos: self.x + 8, self.y + self.height - 60
                size: 32, 22
            Ellipse:
                pos: self.x + 18, self.y + self.height - 68
                size: 18, 14
            Ellipse:
                pos: self.right - 40, self.y + self.height - 60
                size: 32, 22
            Ellipse:
                pos: self.right - 36, self.y + self.height - 68
                size: 18, 14

        Widget:
            size_hint_y: 0.2

        Label:
            text: "灼 兆 中"
            font_size: "36sp"
            bold: True
            color: 0.84, 0.67, 0.30, 1
            size_hint_y: None
            height: 60
        Label:
            text: "烈火焚龟 · 神灵示兆"
            font_size: "14sp"
            color: 0.75, 0.18, 0.12, 1
            size_hint_y: None
            height: 24
        Label:
            text: "天地正在聆听你的祈问..."
            font_size: "13sp"
            color: 0.5, 0.45, 0.38, 1
            size_hint_y: None
            height: 24

        Widget:
            size_hint_y: 1


<ResultScreen>:
    name: "result"
    BoxLayout:
        orientation: "vertical"
        canvas.before:
            Color:
                rgba: 0.06, 0.04, 0.02, 1
            Rectangle:
                pos: self.pos
                size: self.size
        canvas.after:
            # 两侧云纹
            Color:
                rgba: 0.82, 0.63, 0.25, 0.04
            Ellipse:
                pos: self.x + 4, self.y + self.height - 50
                size: 28, 20
            Ellipse:
                pos: self.right - 32, self.y + self.height - 50
                size: 28, 20
            # 底部凤羽弧线
            Color:
                rgba: 0.75, 0.18, 0.12, 0.02
            Line:
                points:
                    self.x - 5, self.y + 40, self.center_x, self.y + 20, self.right + 5, self.y + 40
                width: 25

        # ---- 顶部栏 ----
        BoxLayout:
            size_hint_y: None
            height: 48
            padding: 16, 6
            canvas.before:
                Color:
                    rgba: 0.10, 0.07, 0.04, 0.6
                Rectangle:
                    pos: self.pos
                    size: self.size
            Label:
                text: "卜 辞"
                font_size: "20sp"
                bold: True
                color: 0.84, 0.67, 0.30, 1
                size_hint_x: 0.5
            Label:
                id: auspice_label
                text: ""
                font_size: "11sp"
                bold: True
                color: 0.84, 0.67, 0.30, 1
                size_hint_x: 0.3
                halign: "center"
            Label:
                text: "贞人·灼兆解"
                font_size: "11sp"
                color: 0.50, 0.42, 0.30, 1
                size_hint_x: 0.3

        DecorTop:

        # ---- 内容区 ----
        ScrollView:
            bar_width: 3
            scroll_type: ['bars', 'content']
            BoxLayout:
                orientation: "vertical"
                padding: 16, 10, 16, 16
                spacing: 14
                size_hint_y: None
                height: self.minimum_height

                # === 龟甲兆纹 ===
                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: max(90, crack_label.texture_size[1] + 60)
                    padding: 14, 12
                    canvas.before:
                        Color:
                            rgba: 0.10, 0.08, 0.04, 0.7
                        Rectangle:
                            pos: self.pos
                            size: self.size
                        Color:
                            rgba: 0.82, 0.63, 0.25, 0.25
                        Line:
                            rectangle: self.x + 1, self.y + 1, self.width - 2, self.height - 2
                            width: 1
                    Label:
                        text: "—  龟 甲 兆 纹  —"
                        font_size: "11sp"
                        bold: True
                        color: 0.75, 0.18, 0.12, 1
                        size_hint_y: None
                        height: 20
                    Label:
                        id: crack_label
                        text: ""
                        font_size: "15sp"
                        color: 0.93, 0.89, 0.78, 1
                        padding: 10, 6
                        text_size: self.width - 20, None
                        size_hint_y: None
                        height: self.texture_size[1] + 16

                # === 卦辞 ===
                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: max(80, oracle_label.texture_size[1] + 56)
                    padding: 14, 12
                    canvas.before:
                        Color:
                            rgba: 0.12, 0.08, 0.03, 0.7
                        Rectangle:
                            pos: self.pos
                            size: self.size
                        Color:
                            rgba: 0.84, 0.67, 0.30, 0.35
                        Line:
                            rectangle: self.x + 1, self.y + 1, self.width - 2, self.height - 2
                            width: 1.2
                        # 印章角标 — 右下
                        Color:
                            rgba: 0.75, 0.18, 0.12, 0.15
                        Rectangle:
                            pos: self.right - 30, self.y + 4
                            size: 22, 22
                    Label:
                        text: "—  卦  辞  —"
                        font_size: "11sp"
                        bold: True
                        color: 0.84, 0.67, 0.30, 1
                        size_hint_y: None
                        height: 20
                    Label:
                        id: oracle_label
                        text: ""
                        font_size: "21sp"
                        bold: True
                        color: 0.84, 0.67, 0.30, 1
                        padding: 10, 6
                        text_size: self.width - 30, None
                        halign: "center"
                        size_hint_y: None
                        height: self.texture_size[1] + 20

                # === 白话解读 ===
                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: max(120, explain_label.texture_size[1] + 60)
                    padding: 14, 12
                    canvas.before:
                        Color:
                            rgba: 0.10, 0.08, 0.04, 0.6
                        Rectangle:
                            pos: self.pos
                            size: self.size
                        Color:
                            rgba: 0.60, 0.55, 0.40, 0.2
                        Line:
                            rectangle: self.x + 1, self.y + 1, self.width - 2, self.height - 2
                            width: 1
                    Label:
                        text: "—  白 话 解 读  —"
                        font_size: "11sp"
                        bold: True
                        color: 0.60, 0.55, 0.40, 1
                        size_hint_y: None
                        height: 20
                    Label:
                        id: explain_label
                        text: ""
                        font_size: "15sp"
                        color: 0.88, 0.84, 0.74, 1
                        padding: 12, 8
                        text_size: self.width - 28, None
                        size_hint_y: None
                        height: self.texture_size[1] + 20
                        line_height: 1.5

        # ---- 底部按钮 ----
        BoxLayout:
            size_hint_y: None
            height: 64
            padding: 16, 8
            spacing: 10
            canvas.before:
                Color:
                    rgba: 0.10, 0.07, 0.04, 0.5
                Rectangle:
                    pos: self.pos
                    size: self.size
            Button:
                text: "再 问 一 事"
                font_size: "15sp"
                bold: True
                color: 0.08, 0.05, 0.02, 1
                background_normal: ""
                background_color: 0.84, 0.67, 0.30, 1
                on_release: root.go_home()
            Button:
                text: "历 史 记 录"
                font_size: "15sp"
                color: 0.84, 0.67, 0.30, 1
                background_normal: ""
                background_color: 0.10, 0.08, 0.04, 0.8
                on_release: root.go_history()


<HistoryScreen>:
    name: "history"
    BoxLayout:
        orientation: "vertical"
        canvas.before:
            Color:
                rgba: 0.06, 0.04, 0.02, 1
            Rectangle:
                pos: self.pos
                size: self.size
        # 标题
        BoxLayout:
            size_hint_y: None
            height: 48
            padding: 16, 6
            canvas.before:
                Color:
                    rgba: 0.10, 0.07, 0.04, 0.6
                Rectangle:
                    pos: self.pos
                    size: self.size
            Label:
                text: "往 昔 卜 辞"
                font_size: "20sp"
                bold: True
                color: 0.84, 0.67, 0.30, 1
        DecorTop:

        # 列表
        RecycleView:
            id: history_list
            viewclass: "HistoryItem"
            RecycleBoxLayout:
                orientation: "vertical"
                padding: 14, 6
                spacing: 6
                size_hint_y: None
                height: self.minimum_height
                default_size_hint: 1, None
                default_size: 0, 85

        # 空状态提示
        Label:
            text: "尚未有任何卜问记录\n返回首页开始你的第一次占卜吧"
            font_size: "13sp"
            color: 0.35, 0.30, 0.22, 1
            size_hint_y: 1
            opacity: 0 if history_list.data else 1

        # 返回
        BoxLayout:
            size_hint_y: None
            height: 56
            padding: 16, 8
            canvas.before:
                Color:
                    rgba: 0.10, 0.07, 0.04, 0.5
                Rectangle:
                    pos: self.pos
                    size: self.size
            Button:
                text: "返 回 首 页"
                font_size: "15sp"
                color: 0.84, 0.67, 0.30, 1
                background_normal: ""
                background_color: 0.10, 0.08, 0.04, 0.8
                on_release:
                    app.root.current = "home"


<HistoryItem@BoxLayout>:
    question: ""
    oracle: ""
    time: ""
    auspice: "无咎 · 安常"
    record_id: ""
    orientation: "horizontal"
    size_hint_y: None
    height: 82
    padding: 10, 8
    canvas.before:
        Color:
            rgba: 0.10, 0.08, 0.04, 0.6
        Rectangle:
            pos: self.pos
            size: self.size
        # 左侧朱砂竖线
        Color:
            rgba: 0.75, 0.18, 0.12, 0.5
        Rectangle:
            pos: self.x + 4, self.y + 6
            size: 2.5, self.height - 12
    BoxLayout:
        orientation: "vertical"
        size_hint_x: 1
        padding: 8, 4, 4, 4
        Label:
            text: root.question
            font_size: "13sp"
            color: 0.88, 0.84, 0.74, 1
            text_size: self.width - 8, None
            size_hint_y: None
            height: 22
            shorten: True
        Label:
            text: root.oracle
            font_size: "15sp"
            bold: True
            color: 0.84, 0.67, 0.30, 1
            text_size: self.width - 8, None
            size_hint_y: None
            height: 24
        BoxLayout:
            size_hint_y: None
            height: 16
            spacing: 8
            Label:
                text: root.time
                font_size: "10sp"
                color: 0.40, 0.35, 0.28, 1
                size_hint_x: None
                width: 120
            Label:
                text: root.auspice
                font_size: "9sp"
                bold: True
                color: 0.60, 0.52, 0.38, 1
                size_hint_x: 1
    Button:
        text: "✕"
        font_size: "14sp"
        color: 0.75, 0.18, 0.12, 0.7
        background_normal: ""
        background_color: 0, 0, 0, 0
        size_hint_x: None
        width: 36
        on_release:
            app.root.get_screen("history").delete_record(root.record_id)
